{
  "manifest_version": 3,
  "name": "Bilibili 下载器 — 视频/音频/字幕",
  "version": "1.1.0",
  "description": "一键下载 B站视频流、音频流和AI字幕。",
  "author": "B站下载器",
  "homepage_url": "https://github.com/yourusername/bilibili-dl",
  "permissions": [
    "activeTab",
    "downloads",
    "cookies",
    "scripting",
    "declarativeNetRequest",
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "*://*.bilibili.com/*",
    "*://*.bilivideo.com/*",
    "*://*.bilivideo.cn/*",
    "*://*.hdslb.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.bilibili.com/video/*",
        "*://www.bilibili.com/bangumi/play/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "bilibili_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
